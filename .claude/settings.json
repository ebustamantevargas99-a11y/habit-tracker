{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run test)",
      "Bash(npm run test:run)",
      "Bash(npm run lint)",
      "Bash(npm run db:migrate)",
      "Bash(npm run db:push)",
      "Bash(npm run db:studio)",
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(npm ci)",
      "Bash(npx prisma:*)",
      "Bash(npx playwright:*)",
      "Bash(npx tsc:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git mv:*)",
      "Bash(git restore:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(rm -rf:*)",
      "Bash(npm audit fix --force:*)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)"
    ]
  }
}
