# Base de datos PostgreSQL (Railway, Supabase, o local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# NextAuth — genera con: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-aqui"

# URL de tu app (cambiar en producción)
NEXTAUTH_URL="http://localhost:3000"

# Base URL pública de la app — preferida sobre NEXTAUTH_URL para resolver
# URLs absolutas (Open Graph, manifest, links de email). Visible al
# bundle del cliente porque empieza con NEXT_PUBLIC_*. Necesario también
# para builds de Capacitor/Tauri que apuntan al backend remoto.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Sentry (opcional — ver docs/SENTRY-SETUP.md)
# Ambas vars tienen el mismo valor (DSN es público, safe exponer al browser)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Upstash Redis (opcional — ver docs/UPSTASH-SETUP.md)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
