datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth (NextAuth required tables) ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // Security timestamps — Fase A seguridad (2026-04-20)
  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // 2FA TOTP
  twoFactorSecret      String?
  twoFactorEnabled     Boolean  @default(false)
  twoFactorBackupCodes String[] @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  profile         UserProfile?
  passwordResetTokens PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  securityEvents  SecurityEvent[]
  habits          Habit[]
  habitLogs       HabitLog[]
  workouts        Workout[]
  exercises       Exercise[]
  personalRecords PersonalRecord[]
  bodyMetrics     BodyMetric[]
  transactions    Transaction[]
  budgets         Budget[]
  bills           Bill[]
  subscriptions   Subscription[]
  wishlistItems   WishlistItem[]
  moodLogs        MoodLog[]
  sleepLogs       SleepLog[]
  dailyPlans      DailyPlan[]
  badges          UserBadge[]
  gamification    Gamification?

  // ── NEW: previously in localStorage ──────────────────────────────────────
  hydrationLogs    HydrationLog[]
  medications      Medication[]
  medicationLogs   MedicationLog[]
  symptomLogs      SymptomLog[]
  appointments     MedicalAppointment[]
  okrObjectives    OKRObjective[]
  projectionConfigs ProjectionConfig[]
  pomodoroSessions PomodoroSession[]
  projects         Project[]
  fastingLogs      FastingLog[]
  challenges       FitnessChallenge[]
  weightLogs       WeightLog[]
  stepsLogs        StepsLog[]
  weeklyPlan       WeeklyPlan[]

  // ── Nutrition ──────────────────────────────────────────────────────────────
  foodItems        FoodItem[]
  mealLogs         MealLog[]
  nutritionGoal    NutritionGoal?

  // ── Organization ───────────────────────────────────────────────────────────
  notes            Note[]
  lifeAreas        LifeArea[]
  weeklyReviews    WeeklyReview[]

  // ── Scoring ────────────────────────────────────────────────────────────────
  lifeScoreSnapshots LifeScoreSnapshot[]

  // ── Reading ────────────────────────────────────────────────────────────────
  books            Book[]
  readingSessions  ReadingSession[]

  // ── Fase 5 extras ──────────────────────────────────────────────────────────
  fastingSessions     FastingSession[]
  meditationSessions  MeditationSession[]
  menstrualCycles     MenstrualCycle[]
  periodLogs          PeriodLog[]
  journalEntries      JournalEntry[]
  timeCapsules        TimeCapsule[]
  focusSessions       FocusSession[]
  morningRituals      MorningRitual[]
  eveningRituals      EveningRitual[]
  emergencyCard       EmergencyCard?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Security — Fase A (2026-04-20) ───────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique  // nunca guardar el token plain, solo hash
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?  // nullable porque puede ser un intento de login con email inexistente
  email     String?  // email con el que se intentó (si falla lookup)
  eventType String   // "login_success","login_failed","register","password_reset_requested","password_reset_completed","email_verified","account_deleted","data_exported","2fa_enabled","2fa_disabled"
  ipAddress String?
  userAgent String?
  metadata  Json?    // detalles específicos del evento
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([email, createdAt])
}

// ─── User Profile & Settings ──────────────────────────────────────────────────

model UserProfile {
  id               String @id @default(cuid())
  userId           String @unique
  bio              String?
  avatar           String?
  timezone         String @default("America/Mexico_City")
  units            String @default("metric")  // "metric" | "imperial"
  language         String @default("es")
  theme            String @default("warm")    // "warm" | "ocean" | "forest" | "rose"
  darkMode         Boolean @default(false)
  weekStartsOn     Int    @default(1)
  stepsGoal        Int    @default(10000)
  waterGoal        Float  @default(2.0)
  sleepGoal        Float  @default(8.0)
  lifeScoreWeights Json   @default("{\"vision\":0.10,\"plan\":0.10,\"productivity\":0.15,\"organization\":0.08,\"finance\":0.15,\"fitness\":0.15,\"nutrition\":0.12,\"wellness\":0.15}")
  visionBoard      Json?

  // ── Onboarding / profile extended (2026-04-19 — Ultimate TRACKER pivote) ───
  onboardingCompleted Boolean   @default(false)
  birthDate           DateTime?
  biologicalSex       String?   // "male" | "female" | "intersex" | "prefer_not_say"
  gender              String?
  pronouns            String?
  heightCm            Float?
  weightKg            Float?
  activityLevel       String?   // "sedentary" | "light" | "moderate" | "active" | "very_active"
  fitnessLevel        String?   // "beginner" | "intermediate" | "advanced"
  conditions          String[]  @default([])
  interests           String[]  @default([])   // ["training","nutrition","mindfulness",...]
  enabledModules      String[]  @default([])   // ["fitness","nutrition","habits",...]
  primaryGoals        String[]  @default([])

  user             User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model Gamification {
  id                       String @id @default(cuid())
  userId                   String @unique
  totalXP                  Int    @default(0)
  currentLevel             Int    @default(1)
  streakInsuranceDays      Int    @default(1)
  streakInsuranceUsedThisWeek Int @default(0)
  user                     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  earnedDate DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ─── Habits ───────────────────────────────────────────────────────────────────

model Habit {
  id            String     @id @default(cuid())
  userId        String
  name          String
  icon          String     @default("✅")
  category      String
  timeOfDay     String     @default("all")
  frequency     String     @default("daily")
  targetDays    Int[]
  streakCurrent Int        @default(0)
  streakBest    Int        @default(0)
  strength      Float      @default(0)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs          HabitLog[]

  @@index([userId, isActive])
}

model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  date      String
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
}

// ─── Fitness ──────────────────────────────────────────────────────────────────

model Exercise {
  id               String           @id @default(cuid())
  userId           String?
  name             String
  muscleGroup      String
  category         String
  equipment        String?
  isCustom         Boolean          @default(false)
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  workoutExercises WorkoutExercise[]
  personalRecords  PersonalRecord[]

  @@index([muscleGroup])
}

model Workout {
  id              String            @id @default(cuid())
  userId          String
  date            String
  name            String
  durationMinutes Int               @default(0)
  totalVolume     Float             @default(0)
  notes           String?
  completed       Boolean           @default(false)
  prsHit          Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises       WorkoutExercise[]

  @@index([userId, date])
}

model WorkoutExercise {
  id         String       @id @default(cuid())
  workoutId  String
  exerciseId String
  notes      String?
  orderIndex Int          @default(0)
  workout    Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise   Exercise     @relation(fields: [exerciseId], references: [id])
  sets       WorkoutSet[]

  @@index([workoutId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weight            Float
  reps              Int
  rpe               Float?
  isPR              Boolean         @default(false)
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)
}

model PersonalRecord {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  exerciseName String
  weight       Float
  reps         Int
  estimated1RM Float
  oneRM        Float?
  fiveRM       Float?
  tenRM        Float?
  date         String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise     Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId, exerciseId])
}

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      String
  type      String
  value     Float
  unit      String
  method    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  weight    Float
  unit      String   @default("kg")
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model StepsLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  steps     Int
  goal      Int      @default(10000)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model FastingLog {
  id          String    @id @default(cuid())
  userId      String
  startTime   DateTime
  endTime     DateTime?
  targetHours Int       @default(16)
  completed   Boolean   @default(false)
  notes       String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model FitnessChallenge {
  id           String   @id @default(cuid())
  userId       String
  name         String
  description  String?
  startDate    String
  endDate      String
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  isCompleted  Boolean  @default(false)
  completedDays Int[]   @default([])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WeeklyPlan {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dayOfWeek Int      // 0=Lunes … 6=Domingo
  exercises Json     // PlanExercise[]
  updatedAt DateTime @updatedAt

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

// ─── Finance ──────────────────────────────────────────────────────────────────

model Transaction {
  id            String   @id @default(cuid())
  userId        String
  date          String
  description   String
  amount        Float
  type          String
  category      String
  subcategory   String?
  paymentMethod String?
  isRecurring   Boolean  @default(false)
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([userId, type])
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  month    String
  category String
  limit    Float
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, category])
  @@index([userId, month])
}

model Bill {
  id          String   @id @default(cuid())
  userId      String
  name        String
  amount      Float
  dueDate     String
  isPaid      Boolean  @default(false)
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  name         String
  amount       Float
  billingCycle String
  renewalDate  String
  category     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WishlistItem {
  id          String   @id @default(cuid())
  userId      String
  name        String
  price       Float
  priority    String
  savedAmount Float    @default(0)
  link        String?
  isPurchased Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Wellness ─────────────────────────────────────────────────────────────────

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  mood      Int
  emotions  String[]
  factors   String[]
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model SleepLog {
  id            String   @id @default(cuid())
  userId        String
  date          String
  bedtime       String
  wakeTime      String
  quality       Int
  durationHours Float
  dreamJournal  String?
  factors       String[]
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model HydrationLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  amountMl  Int      @default(0)
  goalMl    Int      @default(2500)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model Medication {
  id             String           @id @default(cuid())
  userId         String
  name           String
  brand          String?
  dosage         String?
  frequency      String           @default("daily")
  timeOfDay      String?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs           MedicationLog[]
  supplementFacts SupplementFact[]

  @@index([userId])
}

model MedicationLog {
  id           String     @id @default(cuid())
  userId       String
  medicationId String
  date         String
  taken        Boolean    @default(false)
  takenAt      DateTime?
  notes        String?
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([medicationId, date])
  @@index([userId, date])
}

model SupplementFact {
  id            String     @id @default(cuid())
  medicationId  String
  nutrient      String
  amount        String
  dailyValuePct String?
  medication    Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
}

model SymptomLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  symptom   String
  intensity Int
  duration  String?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model MedicalAppointment {
  id          String   @id @default(cuid())
  userId      String
  doctorName  String
  specialty   String
  location    String?
  dateTime    String
  reason      String?
  status      String   @default("pending")
  result      String?
  notes       String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── OKR ──────────────────────────────────────────────────────────────────────

model OKRObjective {
  id          String         @id @default(cuid())
  userId      String
  title       String
  description String?
  type        String         @default("monthly")
  parentId    String?
  startDate   String?
  endDate     String?
  targetValue Float          @default(100)
  unit        String         @default("%")
  progress    Float          @default(0)
  color       String         @default("#B8860B")
  emoji       String         @default("🎯")
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  keyResults  OKRKeyResult[]

  @@index([userId])
}

model OKRKeyResult {
  id           String       @id @default(cuid())
  objectiveId  String
  title        String
  targetValue  Float
  currentValue Float        @default(0)
  unit         String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  objective    OKRObjective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
}

model ProjectionConfig {
  id          String                @id @default(cuid())
  userId      String
  objectiveId String?
  name        String
  model       String                @default("linear")
  baseline    Float
  goal        Float
  unit        String                @default("%")
  startDate   String
  endDate     String
  alertThreshold Float             @default(0.15)
  autoGenerate   Boolean           @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones  ProjectionMilestone[]

  @@index([userId])
}

model ProjectionMilestone {
  id                 String           @id @default(cuid())
  projectionConfigId String
  weekNumber         Int
  targetValue        Float
  actualValue        Float?
  status             String           @default("pending")
  date               String
  recalculated       Boolean          @default(false)
  projectionConfig   ProjectionConfig @relation(fields: [projectionConfigId], references: [id], onDelete: Cascade)
}

// ─── Productivity ─────────────────────────────────────────────────────────────

model PomodoroSession {
  id          String   @id @default(cuid())
  userId      String
  date        String
  task        String?
  duration    Int
  isWork      Boolean  @default(true)
  completedAt DateTime @default(now())
  notes       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model Project {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  color       String        @default("#B8860B")
  emoji       String        @default("🚀")
  status      String        @default("active")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       ProjectTask[]

  @@index([userId])
}

model ProjectTask {
  id          String    @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String    @default("todo")
  priority    String?
  objectiveId String?
  weight      Int       @default(1)
  dueDate     String?
  orderIndex  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
}

// ─── Planner ──────────────────────────────────────────────────────────────────

model DailyPlan {
  id            String      @id @default(cuid())
  userId        String
  date          String
  topPriorities String[]
  rating        Int?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeBlocks    TimeBlock[]

  @@unique([userId, date])
  @@index([userId, date])
}

model TimeBlock {
  id          String    @id @default(cuid())
  dailyPlanId String
  startTime   String
  endTime     String
  title       String
  category    String?
  completed   Boolean   @default(false)
  dailyPlan   DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)

  @@index([dailyPlanId])
}

// ─── Nutrition ────────────────────────────────────────────────────────────────

model FoodItem {
  id          String     @id @default(cuid())
  userId      String
  name        String
  brand       String?
  servingSize Float      @default(100)
  servingUnit String     @default("g")
  calories    Float
  protein     Float      @default(0)
  carbs       Float      @default(0)
  fat         Float      @default(0)
  fiber       Float      @default(0)
  sugar       Float      @default(0)
  sodium      Float      @default(0)
  isCustom    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealItems   MealItem[]

  @@index([userId])
  @@index([userId, name])
}

model MealLog {
  id        String     @id @default(cuid())
  userId    String
  date      String
  mealType  String     // breakfast | lunch | dinner | snack
  name      String?
  notes     String?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     MealItem[]

  @@index([userId, date])
}

model MealItem {
  id         String   @id @default(cuid())
  mealLogId  String
  foodItemId String
  quantity   Float    @default(1)
  unit       String   @default("serving")
  calories   Float
  protein    Float    @default(0)
  carbs      Float    @default(0)
  fat        Float    @default(0)
  mealLog    MealLog  @relation(fields: [mealLogId], references: [id], onDelete: Cascade)
  foodItem   FoodItem @relation(fields: [foodItemId], references: [id])

  @@index([mealLogId])
}

model NutritionGoal {
  id             String   @id @default(cuid())
  userId         String   @unique
  calories       Float    @default(2000)
  protein        Float    @default(150)
  carbs          Float    @default(200)
  fat            Float    @default(65)
  fiber          Float    @default(25)
  waterMl        Int      @default(2500)
  mealsPerDay    Int      @default(3)
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Organization ─────────────────────────────────────────────────────────────

model Note {
  id         String   @id @default(cuid())
  userId     String
  title      String
  content    String   @db.Text
  category   String   @default("general")
  tags       String[]
  isPinned   Boolean  @default(false)
  color      String   @default("#FEFCE8")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
}

model LifeArea {
  id          String   @id @default(cuid())
  userId      String
  name        String
  emoji       String   @default("🎯")
  score       Int      @default(5)   // 1-10
  description String?
  color       String   @default("#B8860B")
  orderIndex  Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model WeeklyReview {
  id              String   @id @default(cuid())
  userId          String
  weekStart       String   // ISO date of Monday
  wins            String[] @default([])
  challenges      String[] @default([])
  learnings       String[] @default([])
  nextWeekGoals   String[] @default([])
  gratitude       String[] @default([])
  overallRating   Int      @default(5)  // 1-10
  energyLevel     Int      @default(5)
  productivityScore Int    @default(5)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

// ─── Life Score snapshots (para histórico visual) ─────────────────────────────

model LifeScoreSnapshot {
  id        String   @id @default(cuid())
  userId    String
  date      String   // YYYY-MM-DD del final del window
  overall   Int      // 0-100
  breakdown Json     // { habits: {score, samples, reason}, fitness: ..., etc. }
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Reading (libros + sesiones de lectura) ───────────────────────────────────

model Book {
  id          String   @id @default(cuid())
  userId      String
  title       String
  author      String?
  totalPages  Int?
  currentPage Int      @default(0)
  status      String   @default("reading")   // reading | finished | want | paused
  rating      Int?     // 1-5
  coverUrl    String?
  genre       String?
  notes       String?  @db.Text
  startedAt   String?  // YYYY-MM-DD
  finishedAt  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions    ReadingSession[]

  @@index([userId, status])
}

model ReadingSession {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  date      String   // YYYY-MM-DD
  pagesRead Int      @default(0)
  minutes   Int?
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([bookId, date])
}

// ─── Fasting (intermittent fasting) ───────────────────────────────────────────

model FastingSession {
  id           String    @id @default(cuid())
  userId       String
  startedAt    DateTime
  endedAt      DateTime?
  targetHours  Int       @default(16)   // 16, 18, 20, 24, 36
  protocol     String?                   // "16:8", "18:6", "OMAD", etc.
  notes        String?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ─── Meditation ───────────────────────────────────────────────────────────────

model MeditationSession {
  id               String   @id @default(cuid())
  userId           String
  date             String   // YYYY-MM-DD
  durationMinutes  Int
  type             String   @default("mindfulness")  // breathing | guided | mindfulness | yoga | body-scan
  moodBefore       Int?
  moodAfter        Int?
  notes            String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ─── Menstrual Cycle ──────────────────────────────────────────────────────────

model MenstrualCycle {
  id            String   @id @default(cuid())
  userId        String
  startDate     String   // YYYY-MM-DD (inicio del período)
  endDate       String?  // fin del período (no del ciclo, del sangrado)
  cycleLength   Int?     // días (calculado al iniciar el siguiente)
  periodLength  Int?     // días de sangrado
  flowHeavy     Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodLogs    PeriodLog[]

  @@unique([userId, startDate])
  @@index([userId, startDate])
}

model PeriodLog {
  id        String   @id @default(cuid())
  userId    String
  cycleId   String?
  date      String
  flow      String   // none | spotting | light | medium | heavy
  symptoms  String[] @default([])  // cramps | headache | bloating | mood_swings | ...
  mood      Int?     // 1-10
  energy    Int?     // 1-10
  libido    Int?     // 1-10
  notes     String?
  createdAt DateTime @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle     MenstrualCycle? @relation(fields: [cycleId], references: [id], onDelete: SetNull)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Journaling ───────────────────────────────────────────────────────────────

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      String
  prompt    String?  // prompt del día (si aplica)
  content   String   @db.Text
  mood      Int?     // 1-10
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// ─── Time Capsule ─────────────────────────────────────────────────────────────

model TimeCapsule {
  id         String    @id @default(cuid())
  userId     String
  message    String    @db.Text
  unlockAt   DateTime
  opened     Boolean   @default(false)
  openedAt   DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, unlockAt])
}

// ─── Focus / Deep Work ────────────────────────────────────────────────────────

model FocusSession {
  id              String    @id @default(cuid())
  userId          String
  startedAt       DateTime
  endedAt         DateTime?
  plannedMinutes  Int       @default(90)
  actualMinutes   Int?
  task            String?
  category        String?   // "work" | "study" | "creative" | "admin"
  interruptions   Int       @default(0)
  rating          Int?      // 1-5 satisfacción
  notes           String?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startedAt])
}

// ─── Morning / Evening rituals ────────────────────────────────────────────────

model MorningRitual {
  id             String   @id @default(cuid())
  userId         String
  date           String
  wakeTime       String?
  hydration      Boolean  @default(false)
  meditation     Boolean  @default(false)
  intention      String?  // intención del día
  gratitude      String[] @default([])
  energy         Int?     // 1-10
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model EveningRitual {
  id             String   @id @default(cuid())
  userId         String
  date           String
  sleepTime      String?
  reflection     String?
  gratitude      String[] @default([])
  tomorrowTop3   String[] @default([])
  medsDone       Boolean  @default(false)
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ─── Emergency Share Card ─────────────────────────────────────────────────────

model EmergencyCard {
  id             String   @id @default(cuid())
  userId         String   @unique
  bloodType      String?
  allergies      String[] @default([])
  conditions     String[] @default([])
  medications    String[] @default([])
  emergencyName  String?
  emergencyPhone String?
  emergencyRelation String?
  notes          String?
  shareToken     String?  @unique
  shareExpiresAt DateTime?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
