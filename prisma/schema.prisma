// ─── Calendar (redesign) ──────────────────────────────────────────────────────

model CalendarEvent {
  id     String @id @default(cuid())
  userId String

  title       String
  description String? @db.Text

  // Temporal
  startAt DateTime
  endAt   DateTime?
  allDay  Boolean   @default(false)

  // Categorización
  type     String  @default("custom") // custom | meeting | appointment | personal | health | travel | social
  category String?
  color    String? // hex del user
  icon     String? // emoji
  location String?

  // Grupo / calendario al que pertenece (estilo iCloud)
  groupId String?
  group   CalendarGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Recurrencia simplificada estilo RRULE: FREQ=DAILY|WEEKLY|MONTHLY;BYDAY=MO,WE,FR;COUNT=10
  recurrence    String?
  recurrenceEnd DateTime?

  // Recordatorio
  reminderMinutes Int?

  // Link a otros módulos (opcional, si es evento "virtual" de otro recurso)
  sourceModule String? // workout | meal | focus | meditation | cycle | habit | fasting
  sourceId     String?

  completed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startAt])
  @@index([userId, type])
  @@index([groupId])
}

// Grupos de calendarios (estilo iCloud sidebar).
// Cada user tiene N grupos; cada evento puede pertenecer a un grupo (opcional).
// visible controla si los eventos del grupo se muestran o se ocultan en UI,
// pero esa visibilidad es por-user y se persiste para que sobreviva reload.
model CalendarGroup {
  id        String          @id @default(cuid())
  userId    String
  name      String
  color     String          @default("#b8860b") // hex del user
  icon      String? // emoji opcional
  visible   Boolean         @default(true)
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    CalendarEvent[]

  @@index([userId])
}

model DayTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String // "Mi lunes de productividad"
  blocks    Json // [{startHour: 7, durHours: 1, title: "Ritual mañana", icon: "🌅"}, ...]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
