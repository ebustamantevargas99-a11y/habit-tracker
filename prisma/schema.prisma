datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Auth (NextAuth required tables) ──────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String    @unique
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  // Security timestamps — Fase A seguridad (2026-04-20)
  passwordChangedAt    DateTime?
  lastLoginAt          DateTime?
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  // 2FA TOTP
  twoFactorSecret      String?
  twoFactorEnabled     Boolean   @default(false)
  twoFactorBackupCodes String[]  @default([])
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts                Account[]
  sessions                Session[]
  profile                 UserProfile?
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  securityEvents          SecurityEvent[]
  habits                  Habit[]
  habitLogs               HabitLog[]
  workouts                Workout[]
  exercises               Exercise[]
  personalRecords         PersonalRecord[]
  bodyMetrics             BodyMetric[]
  transactions            Transaction[]
  budgets                 Budget[]
  financialAccounts       FinancialAccount[]
  recurringTxns           RecurringTransaction[]
  savingsGoals            SavingsGoal[]
  debts                   Debt[]
  investments             Investment[]
  netWorthSnapshots       NetWorthSnapshot[]
  moodLogs                MoodLog[]
  sleepLogs               SleepLog[]
  dailyPlans              DailyPlan[]
  badges                  UserBadge[]
  gamification            Gamification?

  // ── NEW: previously in localStorage ──────────────────────────────────────
  hydrationLogs    HydrationLog[]
  medications      Medication[]
  medicationLogs   MedicationLog[]
  symptomLogs      SymptomLog[]
  appointments     MedicalAppointment[]
  pomodoroSessions PomodoroSession[]
  projects         Project[]
  challenges       FitnessChallenge[]
  weightLogs       WeightLog[]
  stepsLogs        StepsLog[]

  // ── Fitness redesign (2026-04-21 — Fase 9) ─────────────────────────────────
  trainingPrograms TrainingProgram[]
  readinessChecks  ReadinessCheck[]
  cardioSessions   CardioSession[]
  shoes            Shoe[]
  bodyCompositions BodyComposition[]

  // ── Nutrition ──────────────────────────────────────────────────────────────
  foodItems     FoodItem[]
  mealLogs      MealLog[]
  nutritionGoal NutritionGoal?

  // ── Organization ───────────────────────────────────────────────────────────
  notes         Note[]
  lifeAreas     LifeArea[]
  weeklyReviews WeeklyReview[]

  // ── Scoring ────────────────────────────────────────────────────────────────
  lifeScoreSnapshots LifeScoreSnapshot[]

  // ── Reading ────────────────────────────────────────────────────────────────
  books           Book[]
  readingSessions ReadingSession[]

  // ── Fase 5 extras ──────────────────────────────────────────────────────────
  fastingSessions    FastingSession[]
  meditationSessions MeditationSession[]
  menstrualCycles    MenstrualCycle[]
  periodLogs         PeriodLog[]
  journalEntries     JournalEntry[]
  timeCapsules       TimeCapsule[]
  focusSessions      FocusSession[]
  morningRituals     MorningRitual[]
  eveningRituals     EveningRitual[]
  emergencyCard      EmergencyCard?

  // ── Extras finales ─────────────────────────────────────────────────────────
  mealTemplates MealTemplate[]
  recipes       Recipe[]
  bodyPhotos    BodyPhoto[]
  milestones    Milestone[]

  // ── Calendar redesign ──────────────────────────────────────────────────────
  calendarEvents CalendarEvent[]
  dayTemplates   DayTemplate[]
  calendarGroups CalendarGroup[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Security — Fase A (2026-04-20) ───────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // nunca guardar el token plain, solo hash
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String? // nullable porque puede ser un intento de login con email inexistente
  email     String? // email con el que se intentó (si falla lookup)
  eventType String // "login_success","login_failed","register","password_reset_requested","password_reset_completed","email_verified","account_deleted","data_exported","2fa_enabled","2fa_disabled"
  ipAddress String?
  userAgent String?
  metadata  Json? // detalles específicos del evento
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([email, createdAt])
}

// ─── User Profile & Settings ──────────────────────────────────────────────────

model UserProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  bio              String?
  avatar           String?
  timezone         String  @default("America/Mexico_City")
  units            String  @default("metric") // "metric" | "imperial"
  primaryCurrency  String  @default("MXN") // ISO 4217 — moneda principal del user
  language         String  @default("es")
  theme            String  @default("warm") // "warm" | "ocean" | "forest" | "rose"
  darkMode         Boolean @default(false)
  weekStartsOn     Int     @default(1)
  stepsGoal        Int     @default(10000)
  waterGoal        Float   @default(2.0)
  sleepGoal        Float   @default(8.0)
  lifeScoreWeights Json    @default("{\"vision\":0.10,\"plan\":0.10,\"productivity\":0.15,\"organization\":0.08,\"finance\":0.15,\"fitness\":0.15,\"nutrition\":0.12,\"wellness\":0.15}")

  // ── Onboarding / profile extended (2026-04-19 — Ultimate TRACKER pivote) ───
  onboardingCompleted Boolean   @default(false)
  quietModeAuto       Boolean   @default(true) // si detecta mood bajo consistente, oculta métricas
  quietModeForced     Boolean   @default(false) // forzado manualmente
  birthDate           DateTime?
  biologicalSex       String? // "male" | "female" | "intersex" | "prefer_not_say"
  gender              String?
  pronouns            String?
  heightCm            Float?
  weightKg            Float?
  activityLevel       String? // "sedentary" | "light" | "moderate" | "active" | "very_active"
  fitnessLevel        String? // "beginner" | "intermediate" | "advanced"
  conditions          String[]  @default([])
  interests           String[]  @default([]) // ["training","nutrition","mindfulness",...]
  enabledModules      String[]  @default([]) // ["fitness","nutrition","habits",...]
  primaryGoals        String[]  @default([])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model Gamification {
  id                          String @id @default(cuid())
  userId                      String @unique
  totalXP                     Int    @default(0)
  currentLevel                Int    @default(1)
  streakInsuranceDays         Int    @default(1)
  streakInsuranceUsedThisWeek Int    @default(0)
  user                        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  earnedDate DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// ─── Habits ───────────────────────────────────────────────────────────────────

model Habit {
  id                 String     @id @default(cuid())
  userId             String
  name               String
  icon               String     @default("✅")
  category           String
  timeOfDay          String     @default("all")
  frequency          String     @default("daily")
  targetDays         Int[]
  streakCurrent      Int        @default(0)
  streakBest         Int        @default(0)
  strength           Float      @default(0)
  isActive           Boolean    @default(true)
  difficulty         String     @default("medium") // tiny | small | medium | large
  // ── Sistema de arraigo ────────────────────────────────────────────────────
  phase              String     @default("not_started") // not_started | starting | forming | strengthening | near_rooted | rooted
  rootedAt           DateTime? // primera vez que cruzó día 92 (fase rooted)
  rootedStreak       Int        @default(0) // días arraigado contador (cuando phase=rooted)
  graceDaysAvailable Int        @default(1) // días de gracia en la semana actual
  graceWeekStart     String? // fecha del lunes de esta semana (YYYY-MM-DD)
  lastCompletedDate  String? // último día marcado como completado
  estimatedMinutes   Int? // tiempo estimado por sesión (para alerta de pérdida)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs               HabitLog[]

  @@index([userId, isActive])
}

model HabitLog {
  id        String   @id @default(cuid())
  userId    String
  habitId   String
  date      String
  completed Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
}

// ─── Fitness ──────────────────────────────────────────────────────────────────

model Exercise {
  id               String            @id @default(cuid())
  userId           String?
  name             String
  muscleGroup      String // legacy (español) — retro-compat
  primaryMuscle    String? // chest | back | shoulders | biceps | triceps | quads | hamstrings | glutes | core | calves | forearms | traps
  secondaryMuscles String[]          @default([])
  category         String
  equipment        String? // legacy single value — retro-compat
  equipmentList    String[]          @default([]) // barbell | dumbbell | machine | cable | bodyweight | kettlebell | band | smith | plate | other
  difficulty       String? // beginner | intermediate | advanced
  description      String?           @db.Text
  formTips         String[]          @default([])
  commonMistakes   String[]          @default([])
  alternatives     String[]          @default([]) // ids de ejercicios alternativos
  isCustom         Boolean           @default(false)
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  workoutExercises WorkoutExercise[]
  personalRecords  PersonalRecord[]

  @@index([muscleGroup])
  @@index([primaryMuscle])
}

model Workout {
  id              String            @id @default(cuid())
  userId          String
  date            String
  name            String
  durationMinutes Int               @default(0)
  totalVolume     Float             @default(0)
  trimp           Float? // Training Impulse score (Banister)
  notes           String?
  completed       Boolean           @default(false)
  prsHit          Int               @default(0)
  plannedPhaseId  String? // link a ProgramPhase (periodización)
  readinessScore  Int? // snapshot del readiness del día (0-100)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises       WorkoutExercise[]
  phase           ProgramPhase?     @relation(fields: [plannedPhaseId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([plannedPhaseId])
}

model WorkoutExercise {
  id         String       @id @default(cuid())
  workoutId  String
  exerciseId String
  notes      String?
  orderIndex Int          @default(0)
  workout    Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise   Exercise     @relation(fields: [exerciseId], references: [id])
  sets       WorkoutSet[]

  @@index([workoutId])
}

model WorkoutSet {
  id                String          @id @default(cuid())
  workoutExerciseId String
  setNumber         Int
  weight            Float
  reps              Int
  rpe               Float? // Rate of Perceived Exertion 0-10
  rir               Int? // Reps in Reserve (10 - rpe). Puede guardarse directo.
  tempo             String? // "3-1-1-2" = ecc-pause-con-pause (segundos)
  setType           String          @default("straight") // straight | warmup | dropset | restpause | myoreps | cluster | superset | amrap | failure
  groupId           String? // identificador común para agrupar supersets (A1+A2)
  isWarmup          Boolean         @default(false)
  isPR              Boolean         @default(false)
  workoutExercise   WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model PersonalRecord {
  id           String   @id @default(cuid())
  userId       String
  exerciseId   String
  exerciseName String
  weight       Float
  reps         Int
  estimated1RM Float
  oneRM        Float?
  fiveRM       Float?
  tenRM        Float?
  date         String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise     Exercise @relation(fields: [exerciseId], references: [id])

  @@index([userId, exerciseId])
}

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      String
  type      String
  value     Float
  unit      String
  method    String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  weight    Float
  unit      String   @default("kg")
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model StepsLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  steps     Int
  goal      Int      @default(10000)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// FastingLog DROPPED (Fase 9 redesign) — consolidado en FastingSession (LifeOS)

model FitnessChallenge {
  id            String   @id @default(cuid())
  userId        String
  name          String
  description   String?
  startDate     String
  endDate       String
  targetValue   Float
  currentValue  Float    @default(0)
  unit          String
  isCompleted   Boolean  @default(false)
  completedDays Int[]    @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// WeeklyPlan DROPPED (Fase 9 redesign) — reemplazado por TrainingProgram + ProgramPhase

// ─── Fitness redesign (Fase 9) — nuevos modelos pro ───────────────────────────

model TrainingProgram {
  id            String         @id @default(cuid())
  userId        String
  name          String
  description   String?        @db.Text
  type          String         @default("linear") // linear | dup | block | conjugate | custom
  goal          String? // hypertrophy | strength | power | endurance | general
  durationWeeks Int
  startDate     String // YYYY-MM-DD
  endDate       String?
  active        Boolean        @default(false) // sólo uno activo por user (enforced en código)
  daysPerWeek   Int            @default(4)
  schedule      Json           @default("[]") // [{dayOfWeek:1, templateName:"Push", exercises:[...]}]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  phases        ProgramPhase[]

  @@index([userId, active])
}

model ProgramPhase {
  id                  String          @id @default(cuid())
  programId           String
  name                String // accumulation | intensification | realization | deload | custom
  weekStart           Int // semana del programa donde empieza (1-indexed)
  weekEnd             Int
  targetRpeMin        Float? // p.ej. 7
  targetRpeMax        Float? // p.ej. 8
  targetSetsPerMuscle Int? // sugerido semanal
  notes               String?
  program             TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  workouts            Workout[]

  @@index([programId, weekStart])
}

model ReadinessCheck {
  id             String   @id @default(cuid())
  userId         String
  date           String // YYYY-MM-DD
  restingHr      Int?
  hrv            Int? // ms (Heart Rate Variability)
  sleepHours     Float?
  sleepQuality   Int? // 1-10
  soreness       Int? // 1-10 (10 = muy adolorido)
  stress         Int? // 1-10
  mood           Int? // 1-10
  energy         Int? // 1-10
  motivation     Int? // 1-10
  score          Int? // 0-100 (calculado)
  recommendation String? // go_hard | moderate | light | rest
  notes          String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model CardioSession {
  id                String    @id @default(cuid())
  userId            String
  date              String // YYYY-MM-DD
  startedAt         DateTime
  endedAt           DateTime?
  activityType      String    @default("run") // run | bike | swim | row | walk | elliptical | hike | other
  distanceKm        Float? // siempre km en DB; UI convierte mi si user imperial
  durationSec       Int // segundos totales
  avgPaceSecPerKm   Float? // pace promedio (segundos por km)
  avgHr             Int? // bpm
  maxHr             Int?
  elevationGainM    Float?
  caloriesBurned    Float?
  perceivedExertion Int? // RPE 1-10
  zones             Json? // {z1:sec, z2:sec, z3:sec, z4:sec, z5:sec}
  splits            Json? // [{km:1, paceSec:300, hr:140}, ...]
  route             Json? // GeoJSON (futuro GPS)
  shoeId            String?
  notes             String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoe              Shoe?     @relation(fields: [shoeId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([userId, activityType, date])
}

model Shoe {
  id             String          @id @default(cuid())
  userId         String
  name           String // "Nike Pegasus 41 azul"
  brand          String?
  model          String?
  purchaseDate   String? // YYYY-MM-DD
  currentKm      Float           @default(0)
  maxKm          Float           @default(800) // km recomendados antes de cambiar
  retired        Boolean         @default(false)
  retiredAt      DateTime?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardioSessions CardioSession[]

  @@index([userId, retired])
}

model BodyComposition {
  id             String   @id @default(cuid())
  userId         String
  date           String // YYYY-MM-DD
  weightKg       Float?
  bodyFatPercent Float?
  leanMassKg     Float?
  fatMassKg      Float?
  waterPercent   Float?
  visceralFat    Float?
  boneMassKg     Float?
  bmr            Int? // basal metabolic rate (kcal)
  method         String? // dexa | bia | caliper | navy_tape | photo_estimate | scale
  notes          String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ═══════════════════════════════════════════════════════════════════════════
// Finance (redesign 2026-04-21) — nivel pro
// Bill, Subscription y WishlistItem fueron reemplazados por
// RecurringTransaction y SavingsGoal respectivamente.
// ═══════════════════════════════════════════════════════════════════════════

model FinancialAccount {
  id            String                 @id @default(cuid())
  userId        String
  name          String
  type          String // checking | savings | credit | investment | loan | crypto | cash
  currency      String                 @default("MXN")
  balance       Float                  @default(0)
  creditLimit   Float?
  interestRate  Float?
  institution   String?
  color         String?
  icon          String?
  archived      Boolean                @default(false)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  user          User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  Transaction[]          @relation("TransactionAccount")
  transfersFrom Transaction[]          @relation("TransferFrom")
  recurrents    RecurringTransaction[]
  investments   Investment[]

  @@index([userId])
  @@index([userId, archived])
}

model Transaction {
  id                  String            @id @default(cuid())
  userId              String
  accountId           String
  date                String
  amount              Float // siempre positivo; el type da el signo
  type                String // income | expense | transfer
  category            String
  subcategory         String?
  merchant            String?
  description         String?
  notes               String?
  tags                String[]          @default([])
  photoData           String?           @db.Text // base64 receipt
  recurringId         String?
  transferToAccountId String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  account             FinancialAccount  @relation("TransactionAccount", fields: [accountId], references: [id], onDelete: Cascade)
  transferTo          FinancialAccount? @relation("TransferFrom", fields: [transferToAccountId], references: [id])

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, merchant])
  @@index([accountId, date])
}

model RecurringTransaction {
  id             String           @id @default(cuid())
  userId         String
  accountId      String
  name           String
  amount         Float
  type           String // income | expense
  category       String
  subcategory    String?
  merchant       String?
  frequency      String // weekly | biweekly | monthly | quarterly | annual
  dayOfMonth     Int?
  nextDate       String // próxima fecha programada
  endDate        String?
  active         Boolean          @default(true)
  autoLog        Boolean          @default(true) // si genera transacción auto al llegar nextDate
  linkedEventId  String? // CalendarEvent vinculado
  lastLoggedDate String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  account        FinancialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId, active])
  @@index([userId, nextDate])
}

model Budget {
  id       String @id @default(cuid())
  userId   String
  month    String
  category String
  limit    Float
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, category])
  @@index([userId, month])
}

model SavingsGoal {
  id              String    @id @default(cuid())
  userId          String
  name            String
  emoji           String?
  targetAmount    Float
  currentAmount   Float     @default(0)
  targetDate      String?
  priority        String? // low | medium | high
  linkedAccountId String?
  category        String? // travel | home | emergency | car | wedding | education | other
  notes           String?
  achieved        Boolean   @default(false)
  achievedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id              String    @id @default(cuid())
  userId          String
  name            String
  type            String // credit_card | loan | mortgage | student | personal | other
  balance         Float
  originalAmount  Float?
  interestRate    Float // anual %
  minPayment      Float
  dueDay          Int?
  linkedAccountId String?
  active          Boolean   @default(true)
  paidOffAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
